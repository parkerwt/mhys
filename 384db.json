[
  {
    "id": 1,
    "name": "乾为天",
    "judgment": "元亨利贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "潜龙勿用。"},
      {"pos": 2, "title": "九二", "text": "见龙在田，利见大人。"},
      {"pos": 3, "title": "九三", "text": "君子终日乾乾，夕惕若，厉无咎。"},
      {"pos": 4, "title": "九四", "text": "或跃在渊，无咎。"},
      {"pos": 5, "title": "九五", "text": "飞龙在天，利见大人。"},
      {"pos": 6, "title": "上九", "text": "亢龙有悔。"}
    ],
    "extra": "用九：见群龙无首，吉。"
  },
  {
    "id": 2,
    "name": "坤为地",
    "judgment": "元亨，利牝马之贞。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "履霜，坚冰至。"},
      {"pos": 2, "title": "六二", "text": "直、方、大，不习无不利。"},
      {"pos": 3, "title": "六三", "text": "含章可贞。或从王事，无成有终。"},
      {"pos": 4, "title": "六四", "text": "括囊，无咎，无誉。"},
      {"pos": 5, "title": "六五", "text": "黄裳，元吉。"},
      {"pos": 6, "title": "上六", "text": "龙战于野，其血玄黄。"}
    ],
    "extra": "用六：利永贞。"
  },
  {
    "id": 3,
    "name": "水雷屯",
    "judgment": "元亨利贞，勿用有攸往，利建侯。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "磐桓，利居贞，利建侯。"},
      {"pos": 2, "title": "六二", "text": "屯如邅如，乘马班如。匪寇婚媾，女子贞不字，十年乃字。"},
      {"pos": 3, "title": "六三", "text": "即鹿无虞，惟入于林中，君子几不如舍，往吝。"},
      {"pos": 4, "title": "六四", "text": "乘马班如，求婚媾，往吉，无不利。"},
      {"pos": 5, "title": "九五", "text": "屯其膏，小贞吉，大贞凶。"},
      {"pos": 6, "title": "上六", "text": "乘马班如，泣血涟如。"}
    ]
  },
  {
    "id": 4,
    "name": "山水蒙",
    "judgment": "亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "发蒙，利用刑人，用说桎梏，以往吝。"},
      {"pos": 2, "title": "九二", "text": "包蒙吉；纳妇吉；子克家。"},
      {"pos": 3, "title": "六三", "text": "勿用取女；见金夫，不有躬，无攸利。"},
      {"pos": 4, "title": "六四", "text": "困蒙，吝。"},
      {"pos": 5, "title": "六五", "text": "童蒙，吉。"},
      {"pos": 6, "title": "上九", "text": "击蒙；不利为寇，利御寇。"}
    ]
  },
  {
    "id": 5,
    "name": "水天需",
    "judgment": "有孚，光亨，贞吉。利涉大川。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "需于郊。利用恒，无咎。"},
      {"pos": 2, "title": "九二", "text": "需于沙。小有言，终吉。"},
      {"pos": 3, "title": "九三", "text": "需于泥，致寇至。"},
      {"pos": 4, "title": "六四", "text": "需于血，出自穴。"},
      {"pos": 5, "title": "九五", "text": "需于酒食，贞吉。"},
      {"pos": 6, "title": "上六", "text": "入于穴，有不速之客三人来，敬之终吉。"}
    ]
  },
  {
    "id": 6,
    "name": "天水讼",
    "judgment": "有孚，窒惕，中吉，终凶。利见大人，不利涉大川。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "不永所事，小有言，终吉。"},
      {"pos": 2, "title": "九二", "text": "不克讼，归而逋，其邑人三百户，无眚。"},
      {"pos": 3, "title": "六三", "text": "食旧德，贞厉，终吉。或从王事，无成。"},
      {"pos": 4, "title": "九四", "text": "不克讼，复即命，渝安贞，吉。"},
      {"pos": 5, "title": "九五", "text": "讼元吉。"},
      {"pos": 6, "title": "上九", "text": "或锡之鞶带，终朝三褫之。"}
    ]
  },
  {
    "id": 7,
    "name": "地水师",
    "judgment": "贞，丈人吉，无咎。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "师出以律，否臧凶。"},
      {"pos": 2, "title": "九二", "text": "在师中，吉无咎，王三锡命。"},
      {"pos": 3, "title": "六三", "text": "师或舆尸，凶。"},
      {"pos": 4, "title": "六四", "text": "师左次，无咎。"},
      {"pos": 5, "title": "六五", "text": "田有禽，利执言，无咎。长子帅师，弟子舆尸，贞凶。"},
      {"pos": 6, "title": "上六", "text": "大君有命，开国承家，小人勿用。"}
    ]
  },
  {
    "id": 8,
    "name": "水地比",
    "judgment": "吉。原筮元永贞，无咎。不宁方来，后夫凶。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "有孚比之，无咎。有孚盈缶，终来有它，吉。"},
      {"pos": 2, "title": "六二", "text": "比之自内，贞吉。"},
      {"pos": 3, "title": "六三", "text": "比之匪人。"},
      {"pos": 4, "title": "六四", "text": "外比之，贞吉。"},
      {"pos": 5, "title": "九五", "text": "显比，王用三驱，失前禽。邑人不诫，吉。"},
      {"pos": 6, "title": "上六", "text": "比之无首，凶。"}
    ]
  },
  {
    "id": 9,
    "name": "风天小畜",
    "judgment": "亨。密云不雨，自我西郊。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "复自道，何其咎，吉。"},
      {"pos": 2, "title": "九二", "text": "牵复，吉。"},
      {"pos": 3, "title": "九三", "text": "舆说辐，夫妻反目。"},
      {"pos": 4, "title": "六四", "text": "有孚，血去惕出，无咎。"},
      {"pos": 5, "title": "九五", "text": "有孚挛如，富以其邻。"},
      {"pos": 6, "title": "上九", "text": "既雨既处，尚德载，妇贞厉。月几望，君子征凶。"}
    ]
  },
  {
    "id": 10,
    "name": "天泽履",
    "judgment": "履虎尾，不咥人，亨。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "素履，往无咎。"},
      {"pos": 2, "title": "九二", "text": "履道坦坦，幽人贞吉。"},
      {"pos": 3, "title": "六三", "text": "眇能视，跛能履，履虎尾，咥人，凶。武人为此大君。"},
      {"pos": 4, "title": "九四", "text": "履虎尾，愬愬终吉。"},
      {"pos": 5, "title": "九五", "text": "夬履，贞厉。"},
      {"pos": 6, "title": "上九", "text": "视履考祥，其旋元吉。"}
    ]
  },
  {
    "id": 11,
    "name": "地天泰",
    "judgment": "小往大来，吉亨。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "拔茅茹，以其汇，征吉。"},
      {"pos": 2, "title": "九二", "text": "包荒，用冯河，不遐遗，朋亡，得尚于中行。"},
      {"pos": 3, "title": "九三", "text": "无平不陂，无往不复，艰贞无咎。勿恤其孚，于食有福。"},
      {"pos": 4, "title": "六四", "text": "翩翩，不富以其邻，不戒以孚。"},
      {"pos": 5, "title": "六五", "text": "帝乙归妹，以祉元吉。"},
      {"pos": 6, "title": "上六", "text": "城复于隍，勿用师。自邑告命，贞吝。"}
    ]
  },
  {
    "id": 12,
    "name": "天地否",
    "judgment": "否之匪人，不利君子贞。大往小来。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "拔茅茹，以其汇，贞吉亨。"},
      {"pos": 2, "title": "六二", "text": "包承。小人吉，大人否亨。"},
      {"pos": 3, "title": "六三", "text": "包羞。"},
      {"pos": 4, "title": "九四", "text": "有命无咎，畴离祉。"},
      {"pos": 5, "title": "九五", "text": "休否，大人吉。其亡其亡，系于苞桑。"},
      {"pos": 6, "title": "上九", "text": "倾否，先否后喜。"}
    ]
  },
  {
    "id": 13,
    "name": "天火同人",
    "judgment": "同人于野，亨。利涉大川，利君子贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "同人于门，无咎。"},
      {"pos": 2, "title": "六二", "text": "同人于宗，吝。"},
      {"pos": 3, "title": "九三", "text": "伏戎于莽，升其高陵，三岁不兴。"},
      {"pos": 4, "title": "九四", "text": "乘其墉，弗克攻，吉。"},
      {"pos": 5, "title": "九五", "text": "同人，先号啕而后笑。大师克相遇。"},
      {"pos": 6, "title": "上九", "text": "同人于郊，无悔。"}
    ]
  },
  {
    "id": 14,
    "name": "火天大有",
    "judgment": "元亨。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "无交害，匪咎，艰则无咎。"},
      {"pos": 2, "title": "九二", "text": "大车以载，有攸往，无咎。"},
      {"pos": 3, "title": "九三", "text": "公用亨于天子，小人弗克。"},
      {"pos": 4, "title": "九四", "text": "匪其彭，无咎。"},
      {"pos": 5, "title": "六五", "text": "厥孚交如，威如；吉。"},
      {"pos": 6, "title": "上九", "text": "自天佑之，吉无不利。"}
    ]
  },
  {
    "id": 15,
    "name": "地山谦",
    "judgment": "亨，君子有终。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "谦谦君子，用涉大川，吉。"},
      {"pos": 2, "title": "六二", "text": "鸣谦，贞吉。"},
      {"pos": 3, "title": "九三", "text": "劳谦君子，有终吉。"},
      {"pos": 4, "title": "六四", "text": "无不利，撝谦。"},
      {"pos": 5, "title": "六五", "text": "不富以其邻，利用侵伐，无不利。"},
      {"pos": 6, "title": "上六", "text": "鸣谦，利用行师，征邑国。"}
    ]
  },
  {
    "id": 16,
    "name": "雷地豫",
    "judgment": "利建侯行师。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "鸣豫，凶。"},
      {"pos": 2, "title": "六二", "text": "介于石，不终日，贞吉。"},
      {"pos": 3, "title": "六三", "text": "盱豫，悔。迟有悔。"},
      {"pos": 4, "title": "九四", "text": "由豫，大有得。勿疑。朋盍簪。"},
      {"pos": 5, "title": "六五", "text": "贞疾，恒不死。"},
      {"pos": 6, "title": "上六", "text": "冥豫，成有渝，无咎。"}
    ]
  },
  {
    "id": 17,
    "name": "泽雷随",
    "judgment": "元亨利贞，无咎。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "官有渝，贞吉。出门交有功。"},
      {"pos": 2, "title": "六二", "text": "系小子，失丈夫。"},
      {"pos": 3, "title": "六三", "text": "系丈夫，失小子。随有求得，利居贞。"},
      {"pos": 4, "title": "九四", "text": "随有获，贞凶。有孚在道，以明，何咎。"},
      {"pos": 5, "title": "九五", "text": "孚于嘉，吉。"},
      {"pos": 6, "title": "上六", "text": "拘系之，乃从维之。王用亨于西山。"}
    ]
  },
  {
    "id": 18,
    "name": "山风蛊",
    "judgment": "元亨，利涉大川。先甲三日，后甲三日。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "干父之蛊，有子，考无咎，厉终吉。"},
      {"pos": 2, "title": "九二", "text": "干母之蛊，不可贞。"},
      {"pos": 3, "title": "九三", "text": "干父之蛊，小有悔，无大咎。"},
      {"pos": 4, "title": "六四", "text": "裕父之蛊，往见吝。"},
      {"pos": 5, "title": "六五", "text": "干父之蛊，用誉。"},
      {"pos": 6, "title": "上九", "text": "不事王侯，高尚其事。"}
    ]
  },
  {
    "id": 19,
    "name": "地泽临",
    "judgment": "元亨利贞。至于八月有凶。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "咸临，贞吉。"},
      {"pos": 2, "title": "九二", "text": "咸临，吉无不利。"},
      {"pos": 3, "title": "六三", "text": "甘临，无攸利。既忧之，无咎。"},
      {"pos": 4, "title": "六四", "text": "至临，无咎。"},
      {"pos": 5, "title": "六五", "text": "知临，大君之宜，吉。"},
      {"pos": 6, "title": "上六", "text": "敦临，吉无咎。"}
    ]
  },
  {
    "id": 20,
    "name": "风地观",
    "judgment": "盥而不荐，有孚颙若。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "童观，小人无咎，君子吝。"},
      {"pos": 2, "title": "六二", "text": "闚观，利女贞。"},
      {"pos": 3, "title": "六三", "text": "观我生，进退。"},
      {"pos": 4, "title": "六四", "text": "观国之光，利用宾于王。"},
      {"pos": 5, "title": "九五", "text": "观我生，君子无咎。"},
      {"pos": 6, "title": "上九", "text": "观其生，君子无咎。"}
    ]
  },
  {
    "id": 21,
    "name": "火雷噬嗑",
    "judgment": "亨。利用狱。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "夦校灭趾，无咎。"},
      {"pos": 2, "title": "六二", "text": "噬肤灭鼻，无咎。"},
      {"pos": 3, "title": "六三", "text": "噬腊肉，遇毒；小吝，无咎。"},
      {"pos": 4, "title": "九四", "text": "噬干胏，得金矢，利艰贞，吉。"},
      {"pos": 5, "title": "六五", "text": "噬干肉，得黄金，贞厉，无咎。"},
      {"pos": 6, "title": "上九", "text": "何校灭耳，凶。"}
    ]
  },
  {
    "id": 22,
    "name": "山火贲",
    "judgment": "亨。小利有攸往。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "贲其趾，舍车而徒。"},
      {"pos": 2, "title": "六二", "text": "贲其须。"},
      {"pos": 3, "title": "九三", "text": "贲如濡如，永贞吉。"},
      {"pos": 4, "title": "六四", "text": "贲如皤如，白马翰如，匪寇婚媾。"},
      {"pos": 5, "title": "六五", "text": "贲于丘园，束帛戋戋，吝，终吉。"},
      {"pos": 6, "title": "上九", "text": "白贲，无咎。"}
    ]
  },
  {
    "id": 23,
    "name": "山地剥",
    "judgment": "不利有攸往。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "剥床以足，蔑贞凶。"},
      {"pos": 2, "title": "六二", "text": "剥床以辨，蔑贞凶。"},
      {"pos": 3, "title": "六三", "text": "剥之，无咎。"},
      {"pos": 4, "title": "六四", "text": "剥床以肤，凶。"},
      {"pos": 5, "title": "六五", "text": "贯鱼，以宫人宠，无不利。"},
      {"pos": 6, "title": "上九", "text": "硕果不食，君子得舆，小人剥庐。"}
    ]
  },
  {
    "id": 24,
    "name": "地雷复",
    "judgment": "亨。出入无疾，朋来无咎。反复其道，七日来复，利有攸往。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "不远复，无祗悔，元吉。"},
      {"pos": 2, "title": "六二", "text": "休复，吉。"},
      {"pos": 3, "title": "六三", "text": "频复，厉无咎。"},
      {"pos": 4, "title": "六四", "text": "中行独复。"},
      {"pos": 5, "title": "六五", "text": "敦复，无悔。"},
      {"pos": 6, "title": "上六", "text": "迷复，凶，有灾眚。用行师，终有大败，以其国君，凶；至于十年，不克征。"}
    ]
  },
  {
    "id": 25,
    "name": "天雷无妄",
    "judgment": "元亨利贞。其匪正有眚，不利有攸往。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "无妄，往吉。"},
      {"pos": 2, "title": "六二", "text": "不耕获，不菑畲，则利有攸往。"},
      {"pos": 3, "title": "六三", "text": "无妄之灾，或系之牛，行人之得，邑人之灾。"},
      {"pos": 4, "title": "九四", "text": "可贞，无咎。"},
      {"pos": 5, "title": "九五", "text": "无妄之疾，勿药有喜。"},
      {"pos": 6, "title": "上九", "text": "无妄，行有眚，无攸利。"}
    ]
  },
  {
    "id": 26,
    "name": "山天大畜",
    "judgment": "利贞，不家食吉，利涉大川。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "有厉利已。"},
      {"pos": 2, "title": "九二", "text": "舆说輹。"},
      {"pos": 3, "title": "九三", "text": "良马逐，利艰贞。日闲舆卫，利有攸往。"},
      {"pos": 4, "title": "六四", "text": "童牛之牿，元吉。"},
      {"pos": 5, "title": "六五", "text": "豮豕之牙，吉。"},
      {"pos": 6, "title": "上九", "text": "何天之衢，亨。"}
    ]
  },
  {
    "id": 27,
    "name": "山雷颐",
    "judgment": "贞吉。观颐，自求口实。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "舍尔灵龟，观我朵颐，凶。"},
      {"pos": 2, "title": "六二", "text": "颠颐，拂经，于丘颐，征凶。"},
      {"pos": 3, "title": "六三", "text": "拂颐，贞凶，十年勿用，无攸利。"},
      {"pos": 4, "title": "六四", "text": "颠颐吉，虎视眈眈，其欲逐逐，无咎。"},
      {"pos": 5, "title": "六五", "text": "拂经，居贞吉，不可涉大川。"},
      {"pos": 6, "title": "上九", "text": "由颐，厉吉，利涉大川。"}
    ]
  },
  {
    "id": 28,
    "name": "泽风大过",
    "judgment": "栋桡，利有攸往，亨。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "藉用白茅，无咎。"},
      {"pos": 2, "title": "九二", "text": "枯杨生稊，老夫得其女妻，无不利。"},
      {"pos": 3, "title": "九三", "text": "栋桡，凶。"},
      {"pos": 4, "title": "九四", "text": "栋隆，吉；有它吝。"},
      {"pos": 5, "title": "九五", "text": "枯杨生华，老妇得其士夫，无咎无誉。"},
      {"pos": 6, "title": "上六", "text": "过涉灭顶，凶，无咎。"}
    ]
  },
  {
    "id": 29,
    "name": "坎为水",
    "judgment": "习坎，有孚，维心亨，行有尚。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "习坎，入于坎窞，凶。"},
      {"pos": 2, "title": "九二", "text": "坎有险，求小得。"},
      {"pos": 3, "title": "六三", "text": "来之坎坎，险且枕，入于坎窞，勿用。"},
      {"pos": 4, "title": "六四", "text": "樽酒簋贰，用缶，纳约自牖，终无咎。"},
      {"pos": 5, "title": "九五", "text": "坎不盈，祇既平，无咎。"},
      {"pos": 6, "title": "上六", "text": "系用徽纆，置于丛棘，三岁不得，凶。"}
    ]
  },
  {
    "id": 30,
    "name": "离为火",
    "judgment": "利贞，亨。畜牝牛，吉。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "履错然，敬之无咎。"},
      {"pos": 2, "title": "六二", "text": "黄离，元吉。"},
      {"pos": 3, "title": "九三", "text": "日昃之离，不鼓缶而歌，则大耋之嗟，凶。"},
      {"pos": 4, "title": "九四", "text": "突如其来如，焚如，死如，弃如。"},
      {"pos": 5, "title": "六五", "text": "出涕沱若，戚嗟若，吉。"},
      {"pos": 6, "title": "上九", "text": "王用出征，有嘉折首，获匪其丑，无咎。"}
    ]
  },
  {
    "id": 31,
    "name": "泽山咸",
    "judgment": "亨，利贞，取女吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "咸其拇。"},
      {"pos": 2, "title": "六二", "text": "咸其腓，凶，居吉。"},
      {"pos": 3, "title": "九三", "text": "咸其股，执其随，往吝。"},
      {"pos": 4, "title": "九四", "text": "贞吉悔亡，憧憧往来，朋从尔思。"},
      {"pos": 5, "title": "九五", "text": "咸其脢，无悔。"},
      {"pos": 6, "title": "上六", "text": "咸其辅，颊，舌。"}
    ]
  },
  {
    "id": 32,
    "name": "雷风恒",
    "judgment": "亨，无咎，利贞，利有攸往。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "浚恒，贞凶，无攸利。"},
      {"pos": 2, "title": "九二", "text": "悔亡。"},
      {"pos": 3, "title": "九三", "text": "不恒其德，或承之羞，贞吝。"},
      {"pos": 4, "title": "九四", "text": "田无禽。"},
      {"pos": 5, "title": "六五", "text": "恒其德，贞，妇人吉，夫子凶。"},
      {"pos": 6, "title": "上六", "text": "振恒，凶。"}
    ]
  },
  {
    "id": 33,
    "name": "天山遁",
    "judgment": "亨，小利贞。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "遁尾，厉，勿用有攸往。"},
      {"pos": 2, "title": "六二", "text": "执之用黄牛之革，莫之胜说。"},
      {"pos": 3, "title": "九三", "text": "系遁，有疾厉，畜臣妾吉。"},
      {"pos": 4, "title": "九四", "text": "好遁，君子吉，小人否。"},
      {"pos": 5, "title": "九五", "text": "嘉遁，贞吉。"},
      {"pos": 6, "title": "上九", "text": "肥遁，无不利。"}
    ]
  },
  {
    "id": 34,
    "name": "雷天大壮",
    "judgment": "利贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "壮于趾，征凶，有孚。"},
      {"pos": 2, "title": "九二", "text": "贞吉。"},
      {"pos": 3, "title": "九三", "text": "小人用壮，君子用罔，贞厉。羝羊触藩，羸其角。"},
      {"pos": 4, "title": "九四", "text": "贞吉悔亡，藩决不羸，壮于大舆之輹。"},
      {"pos": 5, "title": "六五", "text": "丧羊于易，无悔。"},
      {"pos": 6, "title": "上六", "text": "羝羊触藩，不能退，不能遂，无攸利，艰则吉。"}
    ]
  },
  {
    "id": 35,
    "name": "火地晋",
    "judgment": "康侯用锡马蕃庶，昼日三接。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "晋如，摧如，贞吉。罔孚，裕无咎。"},
      {"pos": 2, "title": "六二", "text": "晋如，愁如，贞吉。受兹介福，于其王母。"},
      {"pos": 3, "title": "六三", "text": "众允，悔亡。"},
      {"pos": 4, "title": "九四", "text": "晋如鼫鼠，贞厉。"},
      {"pos": 5, "title": "六五", "text": "悔亡，失得勿恤，往吉无不利。"},
      {"pos": 6, "title": "上九", "text": "晋其角，维用伐邑，厉吉无咎，贞吝。"}
    ]
  },
  {
    "id": 36,
    "name": "地火明夷",
    "judgment": "利艰贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "明夷于飞，垂其翼。君子于行，三日不食，有攸往，主人有言。"},
      {"pos": 2, "title": "六二", "text": "明夷，夷于左股，用拯马壮，吉。"},
      {"pos": 3, "title": "九三", "text": "明夷于南狩，得其大首，不可疾贞。"},
      {"pos": 4, "title": "六四", "text": "入于左腹，获明夷之心，出于门庭。"},
      {"pos": 5, "title": "六五", "text": "箕子之明夷，利贞。"},
      {"pos": 6, "title": "上六", "text": "不明晦，初登于天，后入于地。"}
    ]
  },
  {
    "id": 37,
    "name": "风火家人",
    "judgment": "利女贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "闲有家，悔亡。"},
      {"pos": 2, "title": "六二", "text": "无攸遂，在中馈，贞吉。"},
      {"pos": 3, "title": "九三", "text": "家人嗃嗃，悔厉吉；妇子嘻嘻，终吝。"},
      {"pos": 4, "title": "六四", "text": "富家，大吉。"},
      {"pos": 5, "title": "九五", "text": "王假有家，勿恤吉。"},
      {"pos": 6, "title": "上九", "text": "有孚威如，终吉。"}
    ]
  },
  {
    "id": 38,
    "name": "火泽睽",
    "judgment": "小事吉。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "悔亡，丧马勿逐，自复；见恶人无咎。"},
      {"pos": 2, "title": "九二", "text": "遇主于巷，无咎。"},
      {"pos": 3, "title": "六三", "text": "见舆曳，其牛掣，其人天且劓，无初有终。"},
      {"pos": 4, "title": "九四", "text": "睽孤，遇元夫，交孚，厉无咎。"},
      {"pos": 5, "title": "六五", "text": "悔亡，厥宗噬肤，往何咎。"},
      {"pos": 6, "title": "上九", "text": "睽孤，见豕负涂，载鬼一车，先张之弧，后说之弧，匪寇婚媾，往遇雨则吉。"}
    ]
  },
  {
    "id": 39,
    "name": "水山蹇",
    "judgment": "利西南，不利东北；利见大人，贞吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "往蹇，来誉。"},
      {"pos": 2, "title": "六二", "text": "王臣蹇蹇，匪躬之故。"},
      {"pos": 3, "title": "六三", "text": "往蹇来反。"},
      {"pos": 4, "title": "六四", "text": "往蹇来连。"},
      {"pos": 5, "title": "九五", "text": "大蹇朋来。"},
      {"pos": 6, "title": "上六", "text": "往蹇来硕，吉；利见大人。"}
    ]
  },
  {
    "id": 40,
    "name": "雷水解",
    "judgment": "利西南，无所往，其来复吉。有攸往，夙吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "无咎。"},
      {"pos": 2, "title": "九二", "text": "田获三狐，得黄矢，贞吉。"},
      {"pos": 3, "title": "六三", "text": "负且乘，致寇至，贞吝。"},
      {"pos": 4, "title": "九四", "text": "解而拇，朋至斯孚。"},
      {"pos": 5, "title": "六五", "text": "君子维有解，吉；有孚于小人。"},
      {"pos": 6, "title": "上六", "text": "公用射隼于高墉之上，获之，无不利。"}
    ]
  },
  {
    "id": 41,
    "name": "山泽损",
    "judgment": "有孚，元吉，无咎，可贞，利有攸往。曷之用，二簋可用享。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "已事遄往，无咎，酌损之。"},
      {"pos": 2, "title": "九二", "text": "利贞，征凶，弗损益之。"},
      {"pos": 3, "title": "六三", "text": "三人行，则损一人；一人行，则得其友。"},
      {"pos": 4, "title": "六四", "text": "损其疾，使遄有喜，无咎。"},
      {"pos": 5, "title": "六五", "text": "或益之，十朋之龟弗克违，元吉。"},
      {"pos": 6, "title": "上九", "text": "弗损益之，无咎，贞吉，利有攸往，得臣无家。"}
    ]
  },
  {
    "id": 42,
    "name": "风雷益",
    "judgment": "利有攸往，利涉大川。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "利用为大作，元吉，无咎。"},
      {"pos": 2, "title": "六二", "text": "或益之，十朋之龟弗克违，永贞吉。王用享于帝，吉。"},
      {"pos": 3, "title": "六三", "text": "益之用凶事，无咎。有孚中行，告公用圭。"},
      {"pos": 4, "title": "六四", "text": "中行，告公从。利用为依迁国。"},
      {"pos": 5, "title": "九五", "text": "有孚惠心，勿问元吉。有孚惠我德。"},
      {"pos": 6, "title": "上九", "text": "莫益之，或击之，立心勿恒，凶。"}
    ]
  },
  {
    "id": 43,
    "name": "泽天夬",
    "judgment": "扬于王庭，孚号，有厉，告自邑，不利即戎，利有攸往。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "壮于前趾，往不胜为吝。"},
      {"pos": 2, "title": "九二", "text": "惕号，莫夜有戎，勿恤。"},
      {"pos": 3, "title": "九三", "text": "壮于頄，有凶。君子夬夬，独行遇雨，若濡有愠，无咎。"},
      {"pos": 4, "title": "九四", "text": "臀无肤，其行次且。牵羊悔亡，闻言不信。"},
      {"pos": 5, "title": "九五", "text": "苋陆夬夬，中行无咎。"},
      {"pos": 6, "title": "上六", "text": "无号，终有凶。"}
    ]
  },
  {
    "id": 44,
    "name": "天风姤",
    "judgment": "女壮，勿用取女。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "系于金柅，贞吉。有攸往，见凶，羸豕孚踟躅。"},
      {"pos": 2, "title": "九二", "text": "包有鱼，无咎，不利宾。"},
      {"pos": 3, "title": "九三", "text": "臀无肤，其行次且，厉，无大咎。"},
      {"pos": 4, "title": "九四", "text": "包无鱼，起凶。"},
      {"pos": 5, "title": "九五", "text": "以杞包瓜，含章，有陨自天。"},
      {"pos": 6, "title": "上九", "text": "姤其角，吝，无咎。"}
    ]
  },
  {
    "id": 45,
    "name": "泽地萃",
    "judgment": "亨。王假有庙，利见大人，亨，利贞。用大牲吉，利有攸往。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "有孚不终，乃乱乃萃，若号一握为笑，勿恤，往无咎。"},
      {"pos": 2, "title": "六二", "text": "引吉，无咎，孚乃利用禴。"},
      {"pos": 3, "title": "六三", "text": "萃如，嗟如，无攸利，往无咎，小吝。"},
      {"pos": 4, "title": "九四", "text": "大吉，无咎。"},
      {"pos": 5, "title": "九五", "text": "萃有位，无咎。匪孚，元永贞，悔亡。"},
      {"pos": 6, "title": "上六", "text": "赍咨涕洟，无咎。"}
    ]
  },
  {
    "id": 46,
    "name": "地风升",
    "judgment": "元亨，用见大人，勿忧。南征吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "允升，大吉。"},
      {"pos": 2, "title": "九二", "text": "孚乃利用禴，无咎。"},
      {"pos": 3, "title": "九三", "text": "升虚邑。"},
      {"pos": 4, "title": "王用亨于岐山，吉无咎。"},
      {"pos": 5, "title": "六五", "text": "贞吉，升阶。"},
      {"pos": 6, "title": "上六", "text": "冥升，利于不息之贞。"}
    ]
  },
  {
    "id": 47,
    "name": "泽水困",
    "judgment": "亨，贞，大人吉，无咎，有言不信。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "臀困于株木，入于幽谷，三岁不觌。"},
      {"pos": 2, "title": "九二", "text": "困于酒食，朱绂方来，利用享祀，征凶，无咎。"},
      {"pos": 3, "title": "六三", "text": "困于石，据于蒺藜，入于其宫，不见其妻，凶。"},
      {"pos": 4, "title": "九四", "text": "来徐徐，困于金车，吝，有终。"},
      {"pos": 5, "title": "九五", "text": "夓刖，困于赤绂，乃徐有说，利用祭祀。"},
      {"pos": 6, "title": "上六", "text": "困于葛藟，于臲卼，曰动悔。有悔，征吉。"}
    ]
  },
  {
    "id": 48,
    "name": "水风井",
    "judgment": "改邑不改井，无丧无得，往来井井。汔至，亦未繘井，羸其瓶，凶。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "井泥不食，旧井无禽。"},
      {"pos": 2, "title": "九二", "text": "井谷射鲋，瓮敝漏。"},
      {"pos": 3, "title": "九三", "text": "井渫不食，我心侧，可用汲，王明，并受其福。"},
      {"pos": 4, "title": "六四", "text": "井甃，无咎。"},
      {"pos": 5, "title": "九五", "text": "井冽，寒泉食。"},
      {"pos": 6, "title": "上六", "text": "井收勿幕，有孚元吉。"}
    ]
  },
  {
    "id": 49,
    "name": "泽火革",
    "judgment": "已日乃孚，元亨利贞，悔亡。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "巩用黄牛之革。"},
      {"pos": 2, "title": "六二", "text": "已日乃革之，征吉，无咎。"},
      {"pos": 3, "title": "九三", "text": "征凶，贞厉，革言三就，有孚。"},
      {"pos": 4, "title": "九四", "text": "悔亡，有孚改命，吉。"},
      {"pos": 5, "title": "九五", "text": "大人虎变，未占有孚。"},
      {"pos": 6, "title": "上六", "text": "君子豹变，小人革面，征凶，居贞吉。"}
    ]
  },
  {
    "id": 50,
    "name": "火风鼎",
    "judgment": "元吉，亨。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "鼎颠趾，利出否，得妾以其子，无咎。"},
      {"pos": 2, "title": "九二", "text": "鼎有实，我仇有疾，不我能即，吉。"},
      {"pos": 3, "title": "九三", "text": "鼎耳革，其行塞，雉膏不食，方雨亏悔，终吉。"},
      {"pos": 4, "title": "九四", "text": "鼎折足，覆公餗，其形渥，凶。"},
      {"pos": 5, "title": "六五", "text": "鼎黄耳金铉，利贞。"},
      {"pos": 6, "title": "上九", "text": "鼎玉铉，大吉，无不利。"}
    ]
  },
  {
    "id": 51,
    "name": "震为雷",
    "judgment": "亨。震来虩虩，笑言哑哑。震惊百里，不丧匕鬯。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "震来虩虩，后笑言哑哑，吉。"},
      {"pos": 2, "title": "六二", "text": "震来厉，亿丧贝，跻于九陵，勿逐，七日得。"},
      {"pos": 3, "title": "六三", "text": "震苏苏，震行无眚。"},
      {"pos": 4, "title": "九四", "text": "震遂泥。"},
      {"pos": 5, "title": "六五", "text": "震往来厉，亿无丧，有事。"},
      {"pos": 6, "title": "上六", "text": "震索索，视矍矍，征凶。震不于其躬，于其邻，无咎。婚媾有言。"}
    ]
  },
  {
    "id": 52,
    "name": "艮为山",
    "judgment": "艮其背，不获其身，行其庭，不见其人，无咎。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "艮其趾，无咎，利永贞。"},
      {"pos": 2, "title": "六二", "text": "艮其腓，不拯救其随，其心不快。"},
      {"pos": 3, "title": "九三", "text": "艮其限，列其夤，厉薰心。"},
      {"pos": 4, "title": "六四", "text": "艮其身，无咎。"},
      {"pos": 5, "title": "六五", "text": "艮其辅，言有序，悔亡。"},
      {"pos": 6, "title": "上九", "text": "敦艮，吉。"}
    ]
  },
  {
    "id": 53,
    "name": "风山渐",
    "judgment": "女归吉，利贞。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "鸿渐于干，小子厉，有言，无咎。"},
      {"pos": 2, "title": "六二", "text": "鸿渐于磐，饮食衎衎，吉。"},
      {"pos": 3, "title": "九三", "text": "鸿渐于陆，夫征不复，妇孕不育，凶；利御寇。"},
      {"pos": 4, "title": "六四", "text": "鸿渐于木，或得其桷，无咎。"},
      {"pos": 5, "title": "九五", "text": "鸿渐于陵，妇三岁不孕，终莫之胜，吉。"},
      {"pos": 6, "title": "上九", "text": "鸿渐于逵，其羽可用为仪，吉。"}
    ]
  },
  {
    "id": 54,
    "name": "雷泽归妹",
    "judgment": "征凶，无攸利。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "归妹以娣，跛能履，征吉。"},
      {"pos": 2, "title": "九二", "text": "眇能视，利幽人之贞。"},
      {"pos": 3, "title": "六三", "text": "归妹以须，反归以娣。"},
      {"pos": 4, "title": "九四", "text": "归妹愆期，迟归有时。"},
      {"pos": 5, "title": "六五", "text": "帝乙归妹，其君之袂，不如其娣之袂良，月几望，吉。"},
      {"pos": 6, "title": "上六", "text": "女承筐无实，士刲羊无血，无攸利。"}
    ]
  },
  {
    "id": 55,
    "name": "雷火丰",
    "judgment": "亨，王假之，勿忧，宜日中。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "遇其配主，虽旬无咎，往有尚。"},
      {"pos": 2, "title": "六二", "text": "丰其蔀，日中见斗，往得疑疾，有孚发若，吉。"},
      {"pos": 3, "title": "九三", "text": "丰其沛，日中见沫，折其右肱，无咎。"},
      {"pos": 4, "title": "九四", "text": "丰其蔀，日中见斗，遇其夷主，吉。"},
      {"pos": 5, "title": "六五", "text": "来章，有庆誉，吉。"},
      {"pos": 6, "title": "上六", "text": "丰其屋，蔀其家，窥其户，阒其无人，三岁不觌，凶。"}
    ]
  },
  {
    "id": 56,
    "name": "火山旅",
    "judgment": "小亨，旅贞吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "旅琐琐，斯其所取灾。"},
      {"pos": 2, "title": "六二", "text": "旅即次，怀其资，得童仆贞。"},
      {"pos": 3, "title": "九三", "text": "旅焚其次，丧其童仆，贞厉。"},
      {"pos": 4, "title": "九四", "text": "旅于处，得其资斧，我心不快。"},
      {"pos": 5, "title": "六五", "text": "射雉一矢亡，终以誉命。"},
      {"pos": 6, "title": "上九", "text": "鸟焚其巢，旅人先笑后号啕。丧牛于易，凶。"}
    ]
  },
  {
    "id": 57,
    "name": "巽为风",
    "judgment": "小亨，利有攸往，利见大人。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "进退，利武人之贞。"},
      {"pos": 2, "title": "九二", "text": "巽在床下，用史巫纷若，吉无咎。"},
      {"pos": 3, "title": "九三", "text": "频巽，吝。"},
      {"pos": 4, "title": "六四", "text": "悔亡，田获三品。"},
      {"pos": 5, "title": "九五", "text": "贞吉悔亡，无不利。无初有终，先庚三日，后庚三日，吉。"},
      {"pos": 6, "title": "上九", "text": "巽在床下，丧其资斧，贞凶。"}
    ]
  },
  {
    "id": 58,
    "name": "兑为泽",
    "judgment": "亨，利贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "和兑，吉。"},
      {"pos": 2, "title": "九二", "text": "孚兑，吉，悔亡。"},
      {"pos": 3, "title": "六三", "text": "来兑，凶。"},
      {"pos": 4, "title": "九四", "text": "商兑，未宁，介疾有喜。"},
      {"pos": 5, "title": "九五", "text": "孚于剥，有厉。"},
      {"pos": 6, "title": "上六", "text": "引兑。"}
    ]
  },
  {
    "id": 59,
    "name": "风水涣",
    "judgment": "亨。王假有庙，利涉大川，利贞。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "用拯马壮，吉。"},
      {"pos": 2, "title": "九二", "text": "涣奔其机，悔亡。"},
      {"pos": 3, "title": "六三", "text": "涣其躬，无悔。"},
      {"pos": 4, "title": "六四", "text": "涣其群，元吉。涣有丘，匪夷所思。"},
      {"pos": 5, "title": "九五", "text": "涣汗其大号，涣王居，无咎。"},
      {"pos": 6, "title": "上九", "text": "涣其血，去逖出，无咎。"}
    ]
  },
  {
    "id": 60,
    "name": "水泽节",
    "judgment": "亨。苦节不可贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "不出户庭，无咎。"},
      {"pos": 2, "title": "九二", "text": "不出门庭，凶。"},
      {"pos": 3, "title": "六三", "text": "不节若，则嗟若，无咎。"},
      {"pos": 4, "title": "六四", "text": "安节，亨。"},
      {"pos": 5, "title": "九五", "text": "甘节，吉，往有尚。"},
      {"pos": 6, "title": "上六", "text": "苦节，贞凶，悔亡。"}
    ]
  },
  {
    "id": 61,
    "name": "风泽中孚",
    "judgment": "豚鱼吉，利涉大川，利贞。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "虞吉，有它不燕。"},
      {"pos": 2, "title": "九二", "text": "鸣鹤在阴，其子和之，我有好爵，吾与尔靡之。"},
      {"pos": 3, "title": "六三", "text": "得敌，或鼓或罢，或泣或歌。"},
      {"pos": 4, "title": "六四", "text": "月几望，马匹亡，无咎。"},
      {"pos": 5, "title": "九五", "text": "有孚挛如，无咎。"},
      {"pos": 6, "title": "上九", "text": "翰音登于天，贞凶。"}
    ]
  },
  {
    "id": 62,
    "name": "雷山小过",
    "judgment": "亨，利贞，可小事，不可大事。飞鸟遗之音，不宜上，宜下，大吉。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "飞鸟以凶。"},
      {"pos": 2, "title": "六二", "text": "过其祖，遇其妣；不及其君，遇其臣；无咎。"},
      {"pos": 3, "title": "九三", "text": "弗过防之，从或戕之，凶。"},
      {"pos": 4, "title": "九四", "text": "无咎，弗过遇之。往厉必戒，勿用永贞。"},
      {"pos": 5, "title": "六五", "text": "密云不雨，自我西郊，公弋取彼在穴。"},
      {"pos": 6, "title": "上六", "text": "弗遇过之，飞鸟离之，凶，是谓灾眚。"}
    ]
  },
  {
    "id": 63,
    "name": "水火既济",
    "judgment": "亨小，利贞。初吉终乱。",
    "lines": [
      {"pos": 1, "title": "初九", "text": "曳其轮，濡其尾，无咎。"},
      {"pos": 2, "title": "六二", "text": "妇丧其茀，勿逐，七日得。"},
      {"pos": 3, "title": "九三", "text": "高宗伐鬼方，三年克之，小人勿用。"},
      {"pos": 4, "title": "六四", "text": "繻有衣袽，终日戒。"},
      {"pos": 5, "title": "九五", "text": "东邻杀牛，不如西邻之禴祭，实受其福。"},
      {"pos": 6, "title": "上六", "text": "濡其首，厉。"}
    ]
  },
  {
    "id": 64,
    "name": "火水未济",
    "judgment": "亨。小狐汔济，濡其尾，无攸利。",
    "lines": [
      {"pos": 1, "title": "初六", "text": "濡其尾，吝。"},
      {"pos": 2, "title": "九二", "text": "曳其轮，贞吉。"},
      {"pos": 3, "title": "六三", "text": "未济，征凶，利涉大川。"},
      {"pos": 4, "title": "九四", "text": "贞吉，悔亡，震用伐鬼方，三年有赏于大国。"},
      {"pos": 5, "title": "六五", "text": "贞吉，无悔，君子之光，有孚，吉。"},
      {"pos": 6, "title": "上九", "text": "有孚于饮酒，无咎，濡其首，有孚失是。"}
    ]
  }
]